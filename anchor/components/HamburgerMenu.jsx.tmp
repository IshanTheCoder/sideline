import React from 'react';
import {
  Modal,
  View,
  TouchableOpacity,
  StyleSheet,
  Animated,
  Dimensions,
  Platform,
  StatusBar,
} from 'react-native';
import { ThemedText } from '@/components/themed-text';
import { ThemedView } from '@/components/themed-view';
import { IconSymbol } from '@/components/ui/icon-symbol';
import { Colors } from '@/constants/theme';
import { useColorScheme } from '@/hooks/use-color-scheme';
import { useRouter } from 'expo-router';

const { width } = Dimensions.get('window');
const MENU_WIDTH = Math.min(280, width * 0.75);


  visible;
  onClose: () => void;
  onSignOut: () => void;
}

export default function HamburgerMenu({ visible, onClose, onSignOut }: HamburgerMenuProps) {
  const colorScheme = useColorScheme();
  const router = useRouter();
  const slideAnim = React.useRef(new Animated.Value(-MENU_WIDTH)).current;
  const statusBarHeight = StatusBar.currentHeight || 0;

  React.useEffect(() => {
    if (visible) {
      Animated.spring(slideAnim, {
        toValue: 0,
        useNativeDriver: true,
        tension: 65,
        friction: 10,
      }).start();
    } else {
      Animated.timing(slideAnim, {
        toValue: -MENU_WIDTH,
        duration: 200,
        useNativeDriver: true,
      }).start();
    }
  }, [visible]);

  const handleNavigation = (route) => {
    onClose();
    // Small delay to allow menu to close before navigation
    setTimeout(() => {
      router.push(route as any);
    }, 300);
  };

  const handleSignOut = () => {
    onClose();
    // Small delay to allow menu to close before sign out dialog
    setTimeout(() => {
      onSignOut();
    }, 300);
  };

  const menuItems = [
    {
      id: 'home',
      label: 'Home',
      icon: 'house.fill' as const,
      onPress: () => handleNavigation('/(tabs)/'),
      color: Colors[colorScheme ?? 'light'].tint,
    },
    {
      id: 'record',
      label: 'Start Recording',
      icon: 'mic.fill' as const,
      onPress: () => handleNavigation('/(tabs)/record-details'),
      color: Colors[colorScheme ?? 'light'].tint,
    },
    {
      id: 'games',
      label: 'View Games',
      icon: 'list.bullet' as const,
      onPress: () => handleNavigation('/(tabs)/review'),
      color: Colors[colorScheme ?? 'light'].tint,
    },
    {
      id: 'settings',
      label: 'Settings',
      icon: 'gearshape.fill' as const,
      onPress: () => handleNavigation('/(tabs)/settings'),
      color: Colors[colorScheme ?? 'light'].tint,
    },
    {
      id: 'signout',
      label: 'Sign Out',
      icon: 'rectangle.portrait.and.arrow.right' as const,
      onPress: handleSignOut,
      color: '#FF6B4A',
    },
  ];

  return (
    <Modal
      visible={visible}
      transparent
      animationType="none"
      onRequestClose={onClose}
      statusBarTranslucent
    >
      {/* Backdrop */}
      <TouchableOpacity
        style={styles.backdrop}
        activeOpacity={1}
        onPress={onClose}
      >
        {/* Menu Panel */}
        <Animated.View
          style={[
            styles.menuContainer,
            {
              transform: [{ translateX: slideAnim }],
              backgroundColor: colorScheme === 'dark' ? '#1A1A1A' : '#FFFFFF',
            },
          ]}
        >
          <TouchableOpacity 
            activeOpacity={1} 
            onPress={(e) => e.stopPropagation()}
            style={{ flex: 1 }}
          >
            {/* Header */}
            <ThemedView style={[styles.header, { 
              paddingTop: Platform.OS === 'ios' ? 60 : statusBarHeight + 20 
            }]}>
              
                Menu
              </ThemedText>
              
                <IconSymbol
                  name="xmark"
                  size={24}
                  color={Colors[colorScheme ?? 'light'].text}
                />
              </TouchableOpacity>
            </ThemedView>

            {/* Menu Items */}
            
              {menuItems.map((item, index) => (
                <TouchableOpacity
                  key={item.id}
                  style={[
                    styles.menuItem,
                    index === menuItems.length - 1 && styles.menuItemLast,
                    {
                      borderBottomColor: colorScheme === 'dark' ? '#333' : '#E5E5E5',
                    },
                  ]}
                  onPress={item.onPress}
                  activeOpacity={0.7}
                >
                  <IconSymbol
                    name={item.icon}
                    size={24}
                    color={item.color}
                  />
                  
                    {item.label}
                  </ThemedText>
                </TouchableOpacity>
              ))}
            </View>
          </TouchableOpacity>
        </Animated.View>
      </TouchableOpacity>
    </Modal>
  );
}

const styles = StyleSheet.create({
  backdrop: {
    flex: 1,
    backgroundColor: 'rgba(0, 0, 0, 0.5)',
    margin: 0,
    padding: 0,
  },
  menuContainer: {
    position: 'absolute',
    top: 0,
    bottom: 0,
    left: 0,
    width: MENU_WIDTH,
    shadowColor: '#000',
    shadowOffset: {
      width: 2,
      height: 0,
    },
    shadowOpacity: 0.25,
    shadowRadius: 8,
    elevation: 5,
  },
  header: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingHorizontal: 20,
    paddingBottom: 20,
    borderBottomWidth: 1,
    borderBottomColor: '#E5E5E5',
  },
  headerText: {
    fontSize: 24,
    fontWeight: '700',
  },
  closeButton: {
    padding: 4,
  },
  menuItems: {
    paddingTop: 20,
  },
  menuItem: {
    flexDirection: 'row',
    alignItems: 'center',
    paddingHorizontal: 20,
    paddingVertical: 16,
    borderBottomWidth: 1,
  },
  menuItemLast: {
    marginTop: 10,
    borderTopWidth: 1,
    borderTopColor: '#E5E5E5',
  },
  menuItemText: {
    marginLeft: 16,
    fontSize: 16,
    fontWeight: '600',
  },
});
